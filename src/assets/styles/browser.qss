/* ============================================================
   Rule Card Browser — v3.2.0  (P15.1 Icon System)
   Loaded automatically by bootstrap.apply_theme() alongside
   base.qss / shell.qss / sidebar.qss (alphabetical order).
   ============================================================ */

/* ── Action buttons ── */

QPushButton#BtnAdd,
QPushButton#BtnCopy,
QPushButton#BtnMove {
    background: #1e2538;
    color: #94a3b8;
    border: 1px solid #2a3347;
    border-radius: 3px;
    font-size: 11px;
    padding: 0 8px;
}

QPushButton#BtnAdd:hover,
QPushButton#BtnCopy:hover,
QPushButton#BtnMove:hover {
    background: #2a3450;
    border-color: #3b4a6b;
    color: #cbd5e1;
}

QPushButton#BtnAdd:disabled,
QPushButton#BtnCopy:disabled,
QPushButton#BtnMove:disabled {
    background: #111520;
    color: #2d3748;
    border-color: #1a1f2e;
}

/* Delete — danger style */

QPushButton#BtnDanger {
    background: #1e1214;
    color: #f87171;
    border: 1px solid #7f1d1d;
    border-radius: 3px;
    font-size: 11px;
    padding: 0 8px;
}

QPushButton#BtnDanger:hover {
    background: #2d1517;
    border-color: #ef4444;
}

QPushButton#BtnDanger:disabled {
    background: #0f0d11;
    color: #3b2a2a;
    border-color: #1e1215;
}

/* ── Scroll area & content background ── */

#RuleCardScrollArea {
    background: #0f1117;
    border: 1px solid #1e2435;
    border-radius: 2px;
}

#RuleCardContent {
    background: #0f1117;
}

/* ── Individual card ── */

#RuleCard {
    background: #161b27;
    border: 1px solid #1e2435;
    border-radius: 4px;
    margin: 0px 2px;
}

#RuleCard:hover {
    background: #1e2538;
    border-color: #334155;
}

/* Selected state (cardSelected dynamic property) */
#RuleCard[cardSelected="true"] {
    background: #1a3558;
    border-color: #3b82f6;
}

/* Highlight: cursor match */
#RuleCard[cardHighlight="current"] {
    background: #4a3200;
    border-color: #f59e0b;
}

/* Highlight: other search match */
#RuleCard[cardHighlight="match"] {
    background: #271b00;
    border-color: #78350f;
}

/* Disabled rule — lower contrast */
#RuleCard[cardDisabled="true"] {
    background: #111520;
    border-color: #1a1f2e;
}

/* ── P15.1 action icon beside badge ── */

#RuleCardActionIcon {
    border: none;
    background: transparent;
    padding: 0;
}

/* ── Text elements inside each card ── */

#RuleCardNum {
    color: #475569;
    font-size: 11px;
    min-width: 30px;
}

#RuleCardAction {
    font-size: 11px;
    min-width: 48px;
}

#RuleCardLabel {
    color: #cbd5e1;
    font-size: 12px;
}

#RuleCard[cardDisabled="true"] #RuleCardLabel {
    color: #475569;
}

#RuleCardCategory {
    font-size: 10px;
}

#RuleCardDisabledTag {
    color: #ef4444;
    font-size: 10px;
    font-style: italic;
}

/* ── P13.3 detail row ── */

#RuleCardDetail {
    color: #7a8fa8;
    font-size: 10px;
    font-style: italic;
}

/* ── P13.3 extra-condition count badge ── */

#RuleCardExtraCount {
    color: #94a3b8;
    background: #1e2535;
    border: 1px solid #2a3347;
    border-radius: 3px;
    font-size: 9px;
    padding: 1px 4px;
    font-weight: bold;
}

/* ── P13.3 compact effect badges ── */

#RuleCardFontBadge,
#RuleCardSoundBadge,
#RuleCardMinimapBadge {
    color: #64748b;
    background: #131722;
    border: 1px solid #1e2435;
    border-radius: 3px;
    font-size: 9px;
    padding: 1px 4px;
}

/* ── Section header (non-selectable divider row) ── */

#RuleCardSectionHeader {
    color: #ccaa55;
    background: transparent;
    font-weight: bold;
    font-size: 11px;
    padding: 6px 8px 2px 8px;
    border-bottom: 1px solid #2a2f3c;
    margin-top: 6px;
    margin-bottom: 2px;
}

/* ── Empty state label ── */

#RuleCardEmptyLabel {
    color: #3b4558;
    font-size: 13px;
    padding: 40px;
}
